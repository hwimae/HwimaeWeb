generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  reviews      Review[]
  userReviews  UserReview[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("users")
}

model Story {
  id                    String           @id @default(cuid())
  productId             Int              @unique
  title                 String
  authors               String
  originalPrice         Float?
  currentPrice          Float?
  quantity              Int?
  categoryId            String
  category              Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  averageRating         Float            @default(0)
  reviewCount           Int              @default(0)
  externalAverageRating Float            @default(0)
  externalReviewCount   Int              @default(0)
  userAverageRating     Float            @default(0)
  userReviewCount       Int              @default(0)
  pages                 Int?
  manufacturer          String?
  coverUrl              String?
  discount              Float?
  contentPath           String?
  content               StoryContent?
  reviews               Review[]
  externalReviews       ExternalReview[]
  userReviews           UserReview[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([categoryId])
  @@map("stories")
}

model Category {
  id      String  @id @default(cuid())
  name    String  @unique
  stories Story[]

  @@map("categories")
}

model StoryContent {
  id        String   @id @default(cuid())
  storyId   String   @unique
  content   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("story_contents")
}

model Review {
  id                 String   @id @default(cuid())
  userId             String?
  storyId            String
  externalCustomerId String?
  externalCommentId  String?  @unique
  rating             Float
  title              String
  content            String
  thankCount         Int      @default(0)
  source             String   @default("user")
  reviewedAt         DateTime @default(now())
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  story              Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, storyId])
  @@index([storyId])
  @@map("reviews")
}

model ExternalReview {
  id                 String   @id @default(cuid())
  storyId            String
  externalCustomerId String?
  externalCommentId  String   @unique
  rating             Float
  title              String
  content            String
  thankCount         Int      @default(0)
  reviewedAt         DateTime @default(now())
  story              Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([storyId])
  @@map("external_reviews")
}

model UserReview {
  id         String   @id @default(cuid())
  userId     String
  storyId    String
  rating     Float
  title      String
  content    String
  reviewedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, storyId])
  @@index([storyId])
  @@map("user_reviews")
}
