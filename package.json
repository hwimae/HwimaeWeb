{
  "name": "story-recommendation-platform",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter frontend --filter backend dev",
    "build": "corepack pnpm --recursive build",
    "lint": "corepack pnpm --recursive --if-present lint",
    "test": "corepack pnpm --recursive test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,prisma}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "packageManager": "pnpm@9.12.0"
}
